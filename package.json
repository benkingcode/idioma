{
  "name": "idioma-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "test:e2e": "pnpm --filter idioma-e2e test",
    "test:e2e:ui": "pnpm --filter idioma-e2e test:ui",
    "knip": "knip"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/node": "^20.19.27",
    "dotenv-cli": "^11.0.0",
    "knip": "^5.77.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
