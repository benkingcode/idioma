{
  "name": "@idioma/core",
  "version": "0.1.9",
  "description": "Compile-time React i18n - build tools and CLI",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./babel": {
      "types": "./dist/babel/plugin.d.mts",
      "import": "./dist/babel/plugin.mjs"
    },
    "./babel-preset": {
      "types": "./dist/babel/preset.d.mts",
      "import": "./dist/babel/preset.mjs"
    },
    "./vite": {
      "types": "./dist/bundler/vite.d.mts",
      "import": "./dist/bundler/vite.mjs"
    },
    "./next": {
      "types": "./dist/bundler/next.d.mts",
      "import": "./dist/bundler/next.mjs"
    },
    "./metro": {
      "types": "./dist/bundler/metro.d.mts",
      "import": "./dist/bundler/metro.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "import": "./dist/runtime/index.mjs"
    },
    "./icu": {
      "types": "./dist/icu/index.d.mts",
      "import": "./dist/icu/index.mjs"
    },
    "./keys": {
      "types": "./dist/keys/generator.d.mts",
      "import": "./dist/keys/generator.mjs"
    }
  },
  "bin": {
    "idioma": "./bin/idioma.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^2.11.4",
    "ai": "^6.0.0",
    "chalk": "^5.6.2",
    "chokidar": "^3.6.0",
    "ci-info": "^4.3.1",
    "citty": "^0.1.6",
    "cli-progress": "^3.12.0",
    "consola": "^3.4.2",
    "fast-glob": "^3.3.3",
    "get-tsconfig": "^4.13.7",
    "gettext-parser": "^8.0.0",
    "jiti": "^2.6.1",
    "murmurhash-js": "^1.0.0",
    "ora": "^9.0.0",
    "pathe": "^1.1.2",
    "unplugin": "^1.12.0",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0",
    "metro-config": ">=0.80.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "metro-config": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@babel/core": "^7.28.5",
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/cli-progress": "^3.11.6",
    "@types/gettext-parser": "^4.0.4",
    "@types/murmurhash-js": "^1.0.6",
    "dotenv": "^17.2.3",
    "ignore": "^7.0.5",
    "next": "^16.1.1",
    "vite": "^5.4.21",
    "webpack": "^5.104.1"
  },
  "keywords": [
    "i18n",
    "react",
    "babel",
    "vite",
    "internationalization",
    "localization",
    "translation",
    "cli"
  ],
  "license": "MIT"
}
