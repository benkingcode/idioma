{
  "name": "@idioma/react",
  "version": "0.1.9",
  "description": "Compile-time React i18n - runtime package",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime-suspense": {
      "types": "./dist/runtime-suspense/index.d.ts",
      "import": "./dist/runtime-suspense/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "keywords": [
    "i18n",
    "react",
    "internationalization",
    "localization",
    "translation"
  ],
  "license": "MIT",
  "dependencies": {
    "@idioma/core": "workspace:*"
  }
}
