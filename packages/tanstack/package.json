{
  "name": "@idioma/tanstack",
  "version": "0.1.0",
  "description": "TanStack Router integration for Idioma i18n - SPA and SSR support",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./link": {
      "types": "./dist/link.d.ts",
      "import": "./dist/link.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@idioma/core": "workspace:*",
    "@idioma/react": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-router": ">=1.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-babel": "^6.0.0",
    "@tanstack/react-router": "^1.120.5",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "keywords": [
    "idioma",
    "i18n",
    "tanstack",
    "tanstack-router",
    "internationalization",
    "localization",
    "spa",
    "ssr"
  ],
  "license": "MIT"
}
